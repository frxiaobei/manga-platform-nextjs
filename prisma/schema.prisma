generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum CharacterStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  NEEDS_CHANGES
  PENDING
}

enum AssetCategory {
  HERO
  EXPRESSION
  TURNAROUND
  COSTUME
  OTHER
  ASSET
}

enum CouponStatus {
  ACTIVE
  USED
  EXPIRED
}

model User {
  id           String       @id @default(cuid())
  supabaseId   String       @unique
  email        String       @unique
  name         String?
  bio          String?
  avatar       String?
  role         Role         @default(USER)
  authProvider String       @default("supabase")
  googleSub    String?      @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  characters   Character[]
  ratings      Rating[]
  purchases    Purchase[]
  coupons      Coupon[]
  reviews      Review[]
  auditLogs    AuditLog[]   @relation("AuditLogActor")
  uploadEvents UploadEvent[]
}

model Character {
  id           String          @id @default(cuid())
  name         String
  description  String?
  imageUrl     String?
  price        Decimal         @default(0) @db.Decimal(10, 2)
  status       CharacterStatus @default(PENDING)
  reviewReason String?
  publishedAt  DateTime?
  tagsCsv      String?
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags         CharacterTag[]
  assets       CharacterAsset[]
  ratings      Rating[]
  purchases    Purchase[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
  @@index([userId])
}

model Tag {
  id         String         @id @default(cuid())
  name       String         @unique
  slug       String         @unique
  characters CharacterTag[]
}

model CharacterTag {
  id          String    @id @default(cuid())
  characterId String
  tagId       String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([characterId, tagId])
}

model CharacterAsset {
  id          String        @id @default(cuid())
  characterId String
  category    AssetCategory @default(ASSET)
  url         String
  sortOrder   Int           @default(0)
  character   Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  content   String
  status    String   @default("pending")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rating {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  score       Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, characterId])
}

model Purchase {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  pricePaid   Decimal   @db.Decimal(10, 2)
  couponId    String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, characterId])
}

model Coupon {
  id              String       @id @default(cuid())
  userId          String
  code            String?      @unique
  discountPercent Int          @default(30)
  sourceType      String?
  sourceId        String?
  status          CouponStatus @default(ACTIVE)
  usedAt          DateTime?
  expiresAt       DateTime?
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String?
  entityId    String?
  detail      String?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
}

model UploadEvent {
  id          String   @id @default(cuid())
  userId      String
  eventType   String
  reason      String?
  characterId String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}
